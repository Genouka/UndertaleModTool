<Window x:Class="UndertaleModTool.ImportGraphicsDialog"
        IsVisibleChanged="Window_IsVisibleChanged"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UndertaleModTool"
        xmlns:loc="clr-namespace:UndertaleModTool.Localization"
        mc:Ignorable="d"
        Title="{loc:Loc ImportGraphics_WindowTitle}" Height="650" Width="780" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Folder selection -->
        <Grid Grid.Row="0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Content="{loc:Loc ImportGraphics_ImportFolder}" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <local:TextBoxDark Grid.Column="1" x:Name="ImportFolderTextBox"/>
            <local:ButtonDark Grid.Column="2" x:Name="BrowseButton" Content="{loc:Loc ImportGraphics_Browse}" Click="BrowseButton_Click" Width="80" Margin="5,0,0,0"/>
            <local:ButtonDark Grid.Column="3" x:Name="ScanButton" Content="{loc:Loc ImportGraphics_Scan}" Click="ScanButton_Click" Width="80" Margin="5,0,0,0"/>
        </Grid>

        <!-- Row 1: Global settings (collapsible) -->
        <Expander Grid.Row="1" Header="{loc:Loc ImportGraphics_GlobalSettings}" IsExpanded="False" Margin="0,0,0,5">
            <StackPanel Margin="20,5,0,0">
                <TextBlock Text="{loc:Loc ImportGraphics_DefaultImportMode}" FontWeight="Bold" Margin="3"/>
                <RadioButton x:Name="ReplaceInPlaceRadio" Content="{loc:Loc ImportGraphics_ReplaceInPlace}" ToolTip="{loc:Loc ImportGraphics_ReplaceInPlaceTip}" IsChecked="True" Margin="20,3,3,3"/>
                <RadioButton x:Name="NewTexturePagesRadio" Content="{loc:Loc ImportGraphics_NewTexturePages}" ToolTip="{loc:Loc ImportGraphics_NewTexturePagesTip}" Margin="20,3,3,3"/>
                <RadioButton x:Name="KeepOriginalTexturePageRadio" Content="{loc:Loc ImportGraphics_KeepOriginalTexturePage}" ToolTip="{loc:Loc ImportGraphics_KeepOriginalTexturePageTip}" Margin="20,3,3,3"/>

                <CheckBox x:Name="ImportUnknownAsSpriteCheck" Content="{loc:Loc ImportGraphics_ImportUnknownAsSprite}" IsChecked="True" Margin="3,10,3,3"/>

                <Separator Margin="3,5"/>

                <TextBlock Text="{loc:Loc ImportGraphics_SpriteProperties}" FontWeight="Bold" Margin="3"/>
                <StackPanel x:Name="SpritePropertiesPanel" Margin="20,0,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=ReplaceInPlaceRadio}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="{loc:Loc ImportGraphics_OriginPosition}"/>
                        <local:ComboBoxDark Grid.Column="1" x:Name="OriginPositionComboBox" SelectedIndex="0">
                            <ComboBoxItem Content="Top Left"/>
                            <ComboBoxItem Content="Top Center"/>
                            <ComboBoxItem Content="Top Right"/>
                            <ComboBoxItem Content="Center Left"/>
                            <ComboBoxItem Content="Center"/>
                            <ComboBoxItem Content="Center Right"/>
                            <ComboBoxItem Content="Bottom Left"/>
                            <ComboBoxItem Content="Bottom Center"/>
                            <ComboBoxItem Content="Bottom Right"/>
                        </local:ComboBoxDark>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="{loc:Loc ImportGraphics_AnimationSpeed}"/>
                        <local:TextBoxDark Grid.Column="1" x:Name="AnimationSpeedTextBox" Text="1"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="{loc:Loc ImportGraphics_PlaybackType}"/>
                        <local:ComboBoxDark Grid.Column="1" x:Name="PlaybackTypeComboBox" SelectedIndex="1">
                            <ComboBoxItem Content="Frames Per Second"/>
                            <ComboBoxItem Content="Frames Per Game Frame"/>
                        </local:ComboBoxDark>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Content="{loc:Loc ImportGraphics_IsSpecialType}" x:Name="IsSpecialTypeCheckBox" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="{loc:Loc ImportGraphics_SpecialVersion}"/>
                        <local:TextBoxDark Grid.Column="1" x:Name="SpecialVersionTextBox" Text="1"/>
                    </Grid>
                </StackPanel>

                <Separator Margin="3,5"/>

                <Grid x:Name="TexturePageSizePanel">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="IsEnabled" Value="False"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=NewTexturePagesRadio}" Value="True">
                                    <Setter Property="IsEnabled" Value="True"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=KeepOriginalTexturePageRadio}" Value="True">
                                    <Setter Property="IsEnabled" Value="True"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="{loc:Loc ImportGraphics_TexturePageSize}"/>
                    <local:ComboBoxDark Grid.Column="1" x:Name="TexturePageSizeComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="2048"/>
                        <ComboBoxItem Content="4096"/>
                        <ComboBoxItem Content="8192"/>
                    </local:ComboBoxDark>
                </Grid>

                <local:ButtonDark x:Name="ApplyDefaultsButton" Content="{loc:Loc ImportGraphics_ApplyDefaults}" Click="ApplyDefaultsButton_Click" Margin="3,10,3,3" HorizontalAlignment="Left"/>
            </StackPanel>
        </Expander>

        <!-- Row 2: Image list -->
        <Grid Grid.Row="2" Margin="0,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="0,0,0,3">
                <TextBlock Text="{loc:Loc ImportGraphics_ImageList}" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <local:ButtonDark x:Name="SelectAllButton" Content="{loc:Loc ImportGraphics_SelectAll}" Click="SelectAllButton_Click" Margin="3,0" Padding="5,1"/>
                    <local:ButtonDark x:Name="DeselectAllButton" Content="{loc:Loc ImportGraphics_DeselectAll}" Click="DeselectAllButton_Click" Margin="3,0" Padding="5,1"/>
                    <local:ButtonDark x:Name="SetSelectedModeButton" Content="{loc:Loc ImportGraphics_SetSelectedMode}" Click="SetSelectedModeButton_Click" Margin="3,0" Padding="5,1"/>
                </StackPanel>
            </DockPanel>
            <local:DataGridDark Grid.Row="1" x:Name="ImageListView" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                SelectionMode="Extended" IsReadOnly="False" HeadersVisibility="Column"
                                VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                PreparingCellForEdit="ImageListView_PreparingCellForEdit">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
                    <DataGridTextColumn Binding="{Binding FileName}" Header="{loc:Loc ImportGraphics_ColumnFileName}" Width="120" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding ImageTypeDisplay}" Header="{loc:Loc ImportGraphics_ColumnType}" Width="70" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding SpriteName}" Header="{loc:Loc ImportGraphics_ColumnSpriteName}" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding FrameIndex}" Header="{loc:Loc ImportGraphics_ColumnFrame}" Width="50" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding DimensionInfo}" Header="{loc:Loc ImportGraphics_ColumnDimensions}" Width="120" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding StatusText}" Header="{loc:Loc ImportGraphics_ColumnStatus}" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Binding="{Binding TexturePageInfo}" Header="{loc:Loc ImportGraphics_ColumnTexturePage}" Width="120" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="{loc:Loc ImportGraphics_ColumnMode}" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ImportModeDisplay}" VerticalAlignment="Center" Margin="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <local:ComboBoxDark x:Name="ModeCombo"
                                    SelectedIndex="{Binding SelectedModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Loaded="ModeCombo_Loaded"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </local:DataGridDark>
        </Grid>

        <!-- Row 3: OK / Cancel -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <local:ButtonDark x:Name="OKButton" Content="{loc:Loc ImportGraphics_OK}" Click="OKButton_Click" Width="80" Height="28"/>
            <local:ButtonDark Content="{loc:Loc ImportGraphics_Cancel}" IsCancel="True" Width="80" Height="28" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
