<UserControl x:Class="UndertaleModTool.EditorSearchReplacePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UndertaleModTool"
             xmlns:loc="clr-namespace:UndertaleModTool.Localization"
             mc:Ignorable="d"
             HorizontalAlignment="Right" VerticalAlignment="Top"
             Margin="0,4,4,0"
             Visibility="Collapsed">
    <Border Background="#FF2D2D2D"
            BorderBrush="#FF4A4A4A"
            BorderThickness="1" Padding="4" CornerRadius="2">
        <StackPanel>
            <DockPanel>
                <Button DockPanel.Dock="Right" Name="CloseButton" Width="20" Height="20" Margin="4,0,0,0"
                        VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="CloseButton_Click"
                        Background="Transparent" BorderThickness="0">
                    <Path Data="M 0,0 L 8,8 M 8,0 L 0,8" Stroke="#FFC0C0C0" StrokeThickness="1.5"/>
                </Button>
                <Button DockPanel.Dock="Right" Name="ToggleReplaceButton" Width="20" Height="20" Margin="2,0"
                        VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="ToggleReplaceButton_Click"
                        ToolTip="{loc:Loc EditorSearch_ToggleReplace}"
                        Background="Transparent" BorderThickness="0">
                    <Path Data="M 2,6 L 10,6 M 6,2 L 6,10" Stroke="#FFC0C0C0" StrokeThickness="1.5"/>
                </Button>
                <StackPanel Orientation="Horizontal">
                    <local:TextBoxDark x:Name="SearchTextBox" Width="180" Height="24" Margin="0,0,4,0"
                             VerticalContentAlignment="Center" VerticalAlignment="Center"
                             TextChanged="SearchTextBox_TextChanged" KeyDown="SearchTextBox_KeyDown"/>
                    <Button Name="FindPrevButton" Width="24" Height="24" Margin="0,0,2,0" Click="FindPrevButton_Click"
                            ToolTip="{loc:Loc EditorSearch_FindPrevious}"
                            Background="Transparent" BorderThickness="0">
                        <Path Data="M 4,8 L 10,4 M 4,8 L 10,12" Stroke="#FFC0C0C0" StrokeThickness="1.5"/>
                    </Button>
                    <Button Name="FindNextButton" Width="24" Height="24" Margin="0,0,4,0" Click="FindNextButton_Click"
                            ToolTip="{loc:Loc EditorSearch_FindNext}"
                            Background="Transparent" BorderThickness="0">
                        <Path Data="M 10,8 L 4,4 M 10,8 L 4,12" Stroke="#FFC0C0C0" StrokeThickness="1.5"/>
                    </Button>
                    <ToggleButton Name="MatchCaseButton" Width="24" Height="24" Margin="0,0,2,0"
                                  ToolTip="{loc:Loc EditorSearch_MatchCase}" FontSize="12" FontWeight="Bold" Content="Aa"
                                  Foreground="#FFC0C0C0" Background="Transparent" BorderBrush="#FF4A4A4A"/>
                    <ToggleButton Name="WholeWordsButton" Width="24" Height="24" Margin="0,0,2,0"
                                  ToolTip="{loc:Loc EditorSearch_WholeWord}" FontSize="12" FontWeight="Bold" Content="W"
                                  Foreground="#FFC0C0C0" Background="Transparent" BorderBrush="#FF4A4A4A"/>
                    <ToggleButton Name="UseRegexButton" Width="24" Height="24"
                                  ToolTip="{loc:Loc EditorSearch_UseRegex}" FontSize="11" FontWeight="Bold" Content=".*"
                                  Foreground="#FFC0C0C0" Background="Transparent" BorderBrush="#FF4A4A4A"/>
                </StackPanel>
            </DockPanel>
            <DockPanel Name="ReplacePanel" Margin="0,4,0,0" Visibility="Collapsed">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="4,0,0,0">
                    <local:ButtonDark x:Name="ReplaceButton" Width="48" Height="24" Margin="0,0,2,0" Click="ReplaceButton_Click"
                            Content="{loc:Loc EditorSearch_Replace}" FontSize="11"/>
                    <local:ButtonDark x:Name="ReplaceAllButton" Width="60" Height="24" Click="ReplaceAllButton_Click"
                            Content="{loc:Loc EditorSearch_ReplaceAll}" FontSize="11"/>
                </StackPanel>
                <local:TextBoxDark x:Name="ReplaceTextBox" Height="24" VerticalContentAlignment="Center"
                         KeyDown="ReplaceTextBox_KeyDown"/>
            </DockPanel>
        </StackPanel>
    </Border>
</UserControl>
